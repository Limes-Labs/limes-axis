    "test": "vitest run",
    "test:e2e": "export NEXT_PUBLIC_AXIS_API_BASE_URL=http://127.0.0.1:65534; next build && playwright test",
    "test:e2e:live": "export NEXT_PUBLIC_AXIS_API_BASE_URL=http://127.0.0.1:8000 AXIS_E2E_LIVE_API=1; next build && playwright test e2e/live-overview.spec.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "lucide-react": "^1.21.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
