  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "eslint .",
    "start": "next start",
    "test": "vitest run",
    "test:e2e": "export NEXT_PUBLIC_AXIS_API_BASE_URL=http://127.0.0.1:65534; next build && playwright test",
    "test:e2e:live": "export NEXT_PUBLIC_AXIS_API_BASE_URL=http://127.0.0.1:8000 AXIS_E2E_LIVE_API=1; next build && playwright test e2e/live-overview.spec.ts",
    "test:e2e:stories": "export NEXT_PUBLIC_AXIS_API_BASE_URL=http://127.0.0.1:8000 AXIS_E2E_LIVE_API=1; next build && playwright test e2e/control-room.spec.ts e2e/connectors-flow.spec.ts e2e/onboarding.spec.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "geist": "^1.7.2",
    "lucide-react": "^1.21.0",
    "next": "^16.2.9",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
