{
  "$schema": "http://json-schema.org/schema#",
  "type": "object",
  "description": "values.schema.json provides schema validation for the Limes Axis Helm chart deployment boundary.",
  "properties": {
    "api": {
      "type": "object",
      "properties": {
        "replicaCount": {
          "type": "integer",
          "minimum": 1
        },
        "revisionHistoryLimit": {
          "type": "integer",
          "minimum": 0
        },
        "env": {
          "type": "object",
          "properties": {
            "AXIS_POSTGRES_CONNECT_TIMEOUT_SECONDS": {
              "type": "string",
              "pattern": "^[0-9]+$"
            },
            "AXIS_POSTGRES_POOL_TIMEOUT_SECONDS": {
              "type": "string",
              "pattern": "^[0-9]+(\\.[0-9]+)?$"
            },
            "AXIS_USAGE_METERING_ENABLED": {
              "type": "string",
              "enum": ["true", "false"]
            },
            "AXIS_USAGE_METERING_FAILURE_MODE": {
              "type": "string",
              "enum": ["open", "closed"]
            },
            "AXIS_USAGE_METERING_ADMISSION_STATEMENT_TIMEOUT_MS": {
              "type": "string",
              "pattern": "^[0-9]+$"
            },
            "AXIS_USAGE_METERING_FLUSH_INTERVAL_SECONDS": {
              "type": "string",
              "pattern": "^[0-9]+(\\.[0-9]+)?$"
            },
            "AXIS_USAGE_METERING_AGGREGATION_WINDOW_SECONDS": {
              "type": "string",
              "pattern": "^[0-9]+$"
            },
            "AXIS_USAGE_METERING_PROJECTION_BATCH_SIZE": {
              "type": "string",
              "pattern": "^[0-9]+$"
            },
            "AXIS_USAGE_METERING_PROJECTION_MAX_BATCHES_PER_TICK": {
              "type": "string",
              "pattern": "^[0-9]+$"
            },
            "AXIS_USAGE_METERING_PROJECTION_FAILURE_THRESHOLD": {
              "type": "string",
              "pattern": "^[0-9]+$"
            },
            "AXIS_USAGE_METERING_PROJECTION_MAX_BACKLOG_AGE_SECONDS": {
              "type": "string",
              "pattern": "^[0-9]+(\\.[0-9]+)?$"
            },
            "AXIS_USAGE_METERING_SHUTDOWN_TIMEOUT_SECONDS": {
              "type": "string",
              "pattern": "^[0-9]+(\\.[0-9]+)?$"
            },
            "AXIS_DEPLOYMENT_TENANCY_MODE": {
              "type": "string",
              "enum": [
                "saas_multi_tenant",
                "single_tenant_managed",
                "private_cloud",
                "on_prem"
              ]
            },
            "AXIS_CONNECTOR_EXPORT_OBJECT_STORE_ADAPTER": {
              "type": "string",
              "enum": [
                "local_filesystem",
                "s3_compatible"
              ]
            },
            "AXIS_CONNECTOR_EXPORT_S3_RETENTION_MODE": {
              "type": "string",
              "enum": [
                "GOVERNANCE",
                "COMPLIANCE"
              ]
            },
            "AXIS_SUPPORT_COVERAGE": {
              "type": "string",
              "enum": [
                "demo_business_hours",
                "business_hours",
                "extended_hours",
                "24x7"
              ]
            }
          }
        },
        "autoscaling": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "minReplicas": {
              "type": "integer",
              "minimum": 1
            },
            "maxReplicas": {
              "type": "integer",
              "minimum": 1
            },
            "targetCPUUtilizationPercentage": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            },
            "targetMemoryUtilizationPercentage": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          }
        },
        "pdb": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "minAvailable": {
              "oneOf": [
                {
                  "type": "integer",
                  "minimum": 0
                },
                {
                  "type": "string",
                  "pattern": "^[0-9]+%$"
                }
              ]
            }
          }
        }
      }
    },
    "web": {
      "type": "object",
      "properties": {
        "replicaCount": {
          "type": "integer",
          "minimum": 1
        },
        "revisionHistoryLimit": {
          "type": "integer",
          "minimum": 0
        },
        "autoscaling": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "minReplicas": {
              "type": "integer",
              "minimum": 1
            },
            "maxReplicas": {
              "type": "integer",
              "minimum": 1
            },
            "targetCPUUtilizationPercentage": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            },
            "targetMemoryUtilizationPercentage": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          }
        },
        "pdb": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "minAvailable": {
              "oneOf": [
                {
                  "type": "integer",
                  "minimum": 0
                },
                {
                  "type": "string",
                  "pattern": "^[0-9]+%$"
                }
              ]
            }
          }
        }
      }
    },
    "secrets": {
      "type": "object",
      "properties": {
        "existingSecret": {
          "type": "string",
          "minLength": 1
        },
        "createExample": {
          "type": "boolean"
        },
        "externalSecret": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "refreshPolicy": {
              "type": "string",
              "enum": [
                "CreatedOnce",
                "Periodic",
                "OnChange"
              ]
            },
            "refreshInterval": {
              "type": "string",
              "minLength": 1
            },
            "secretStoreRef": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "kind": {
                  "type": "string",
                  "enum": [
                    "SecretStore",
                    "ClusterSecretStore"
                  ]
                }
              }
            },
            "target": {
              "type": "object",
              "properties": {
                "creationPolicy": {
                  "type": "string",
                  "enum": [
                    "Owner",
                    "Orphan",
                    "Merge",
                    "None"
                  ]
                },
                "deletionPolicy": {
                  "type": "string",
                  "enum": [
                    "Delete",
                    "Merge",
                    "Retain"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "dnsPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "egressMode": {
          "type": "string",
          "enum": [
            "port_allowlist",
            "restricted",
            "offline"
          ]
        },
        "allowedEgressPorts": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1,
            "maximum": 65535
          }
        },
        "allowedEgressCidrs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "certManager": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "issuerName": {
              "type": "string"
            },
            "issuerKind": {
              "type": "string",
              "enum": [
                "Issuer",
                "ClusterIssuer"
              ]
            },
            "issuerGroup": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "tests": {
      "type": "object",
      "properties": {
        "smoke": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "activeDeadlineSeconds": {
              "type": "integer",
              "minimum": 1
            },
            "retryAttempts": {
              "type": "integer",
              "minimum": 1
            },
            "requestTimeoutSeconds": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    }
  }
}
