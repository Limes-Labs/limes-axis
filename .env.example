AXIS_ENV=development
AXIS_PUBLIC_BASE_URL=http://127.0.0.1:3000
AXIS_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_AXIS_API_BASE_URL=http://127.0.0.1:8000
AXIS_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
# Staleness window for tenant suspension and quota lookups on the hot request
# path; 0 disables caching and reads fresh state on every request.
AXIS_TENANT_STATE_CACHE_TTL_SECONDS=5.0
# Per-tenant usage metering: the cumulative consumption ledger beneath billing
# (quotas are instantaneous ceilings; metering is running accounting). Off by
# default so existing deployments record nothing. When enabled, api_request
# counts are batched in-process and flushed to per-period ledger rows every
# flush interval; connector_sync_rows and session_created are recorded durably.
AXIS_USAGE_METERING_ENABLED=false
AXIS_USAGE_METERING_FLUSH_INTERVAL_SECONDS=5.0
# Aggregation bucket width in seconds (60..86400). 86400 = UTC-day buckets.
AXIS_USAGE_METERING_AGGREGATION_WINDOW_SECONDS=86400
AXIS_POSTGRES_DSN=postgresql+psycopg://axis:axis@localhost:5432/axis
AXIS_TYPEDB_ADDRESS=localhost:1729
AXIS_TYPEDB_HTTP_ADDRESS=http://localhost:8001
AXIS_TYPEDB_USERNAME=admin
AXIS_TYPEDB_PASSWORD=password
AXIS_TYPEDB_DATABASE=axis
# Connector ontology graph promotion writes real, verified entities into TypeDB.
# Off by default (promotions defer and write nothing). When enabling, also load
# the schema once (`python -m axis_api.ontology.bootstrap`) and enable ontology
# queries so promoted nodes can be read back.
AXIS_ONTOLOGY_MUTATIONS_ENABLED=false
AXIS_ONTOLOGY_QUERIES_ENABLED=false
AXIS_TEMPORAL_ADDRESS=localhost:7233
AXIS_TEMPORAL_NAMESPACE=default
AXIS_TEMPORAL_SIGNAL_TIMEOUT_SECONDS=2.0
AXIS_WORKFLOW_SIGNALS_ENABLED=true
# Scheduled/periodic maintenance jobs run by the Temporal worker (services/worker).
# Master enable flag (default false): schedules are always reconciled on worker
# startup but stay paused until this is true, so existing deployments are unaffected.
AXIS_SCHEDULED_JOBS_ENABLED=false
AXIS_SCHEDULED_AUDIT_RETENTION_INTERVAL_SECONDS=86400
AXIS_SCHEDULED_AUDIT_RETENTION_DAYS=365
AXIS_SCHEDULED_AUDIT_RETENTION_DRY_RUN=true
AXIS_SCHEDULED_AUDIT_RETENTION_BATCH_LIMIT=500
AXIS_SCHEDULED_SESSION_SWEEP_INTERVAL_SECONDS=900
AXIS_SCHEDULED_SESSION_SWEEP_BATCH_LIMIT=500
AXIS_SCHEDULED_TENANT_RECONCILIATION_INTERVAL_SECONDS=3600
# OpenTelemetry distributed tracing + metrics (API + worker). Master flag is off
# by default so existing deploys/tests are unaffected: no provider is installed
# and instrumented code paths are no-ops. Enable it and point the OTLP/HTTP
# exporter at a collector (/v1/traces and /v1/metrics are appended). Tenant and
# actor ids are recorded as span attributes; tokens, secrets, and client IPs are
# never recorded (same privacy rules as audit payloads). See
# docs/platform-observability.md.
AXIS_OTEL_ENABLED=false
AXIS_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
AXIS_OTEL_METRICS_ENABLED=true
AXIS_OBJECT_STORE_ENDPOINT=http://localhost:9000
AXIS_OBJECT_STORE_BUCKET=axis-dev
# Governed export object store. The local filesystem adapter is the default for
# demos and CANNOT provide WORM; COMPLIANCE retention requires the s3_compatible
# adapter against a bucket created with S3 object-lock enabled.
AXIS_CONNECTOR_EXPORT_OBJECT_STORE_ADAPTER=local_filesystem
AXIS_CONNECTOR_EXPORT_OBJECT_STORE_ROOT=.axis/object-store
# S3-compatible / MinIO evaluation or production profile:
# AXIS_CONNECTOR_EXPORT_OBJECT_STORE_ADAPTER=s3_compatible
# AXIS_CONNECTOR_EXPORT_S3_ENDPOINT=https://minio.internal:9443
# AXIS_CONNECTOR_EXPORT_S3_REGION=eu-central-1
# AXIS_CONNECTOR_EXPORT_S3_BUCKET=axis-evidence
# AXIS_CONNECTOR_EXPORT_S3_SECURE_TRANSPORT=true
# The bucket MUST be created with object-lock enabled (make_bucket object_lock=true
# / mc mb --with-lock). COMPLIANCE mode fails closed at startup and on export when
# the bucket lacks object-lock, so it cannot silently no-op.
# AXIS_CONNECTOR_EXPORT_S3_OBJECT_LOCK_ENABLED=true
# AXIS_CONNECTOR_EXPORT_S3_RETENTION_MODE=GOVERNANCE  # or COMPLIANCE for WORM
# AXIS_CONNECTOR_EXPORT_S3_RETENTION_DAYS=365
# AXIS_CONNECTOR_EXPORT_S3_LEGAL_HOLD_ENABLED=false
# Access/secret keys must come from a secret manager, never the ConfigMap:
# AXIS_CONNECTOR_EXPORT_S3_ACCESS_KEY=
# AXIS_CONNECTOR_EXPORT_S3_SECRET_KEY=
AXIS_OIDC_ISSUER=http://127.0.0.1:8080/realms/axis
AXIS_OIDC_AUDIENCE=limes-axis-api
AXIS_OIDC_JWKS_URL=http://127.0.0.1:8080/realms/axis/protocol/openid-connect/certs
AXIS_OIDC_ALGORITHMS=["RS256"]
AXIS_OIDC_ACTOR_CLAIM=sub
AXIS_OIDC_TENANT_CLAIM=axis_tenant
AXIS_OIDC_JWKS_CACHE_SECONDS=300
AXIS_OIDC_AUTH_REQUIRED=false
AXIS_OIDC_CLIENT_ID=limes-axis-web
AXIS_OIDC_CLIENT_SECRET=axis-local-dev-secret
AXIS_OIDC_AUTHORIZATION_URL=http://127.0.0.1:8080/realms/axis/protocol/openid-connect/auth
AXIS_OIDC_TOKEN_URL=http://127.0.0.1:8080/realms/axis/protocol/openid-connect/token
AXIS_OIDC_REDIRECT_URI=http://127.0.0.1:8000/identity/oidc/callback
AXIS_OIDC_END_SESSION_URL=http://127.0.0.1:8080/realms/axis/protocol/openid-connect/logout
AXIS_OIDC_POST_LOGOUT_REDIRECT_URI=http://127.0.0.1:3000/
AXIS_OIDC_SESSION_COOKIE_SIGNING_SECRET=axis-local-demo-session-signing-key
AXIS_OIDC_SESSION_COOKIE_SECURE=false
AXIS_OIDC_SESSION_COOKIE_HOST_PREFIX=true
AXIS_OIDC_SESSION_IDLE_TIMEOUT_SECONDS=1800
AXIS_OIDC_SESSION_ABSOLUTE_TIMEOUT_SECONDS=28800
AXIS_OIDC_SESSION_MAX_CONCURRENT=5
# HKDF-derived AES-GCM key material for refresh tokens at rest. Must be at least
# 32 characters or the API refuses to start; leave unset to disable refresh.
AXIS_OIDC_REFRESH_TOKEN_ENCRYPTION_KEY=axis-local-demo-refresh-credential-key
# Only enable behind EXACTLY ONE trusted reverse proxy/ingress: session device
# metadata then records the LAST (rightmost) X-Forwarded-For hop - the peer the
# proxy appended - as the client IP. Keep false when clients can reach the API
# directly, because the header is client-controlled. Multi-proxy chains need a
# trusted-hop count (documented follow-up, not yet implemented).
AXIS_IDENTITY_SESSION_TRUSTED_PROXY_ENABLED=false
AXIS_EXTERNAL_MODEL_EGRESS_ENABLED=false
AXIS_DEPLOYMENT_TENANCY_MODE=saas_multi_tenant
AXIS_DEPLOYMENT_CUSTOMER_ISOLATION_CONFIGURED=false
AXIS_DEPLOYMENT_DATA_RESIDENCY_CONFIGURED=false
AXIS_DEPLOYMENT_OPERATOR_ACCESS_RUNBOOK_CONFIGURED=false
AXIS_DEPLOYMENT_BREAK_GLASS_APPROVAL_CONFIGURED=false
AXIS_CREDENTIAL_LEASE_EXECUTION_ENABLED=false
AXIS_CREDENTIAL_LEASE_PROVIDER_ADAPTERS_ENABLED=false
AXIS_CONNECTOR_SYNC_EXECUTION_ENABLED=false
AXIS_EXTERNAL_DB_SYNC_EXECUTION_ENABLED=false
AXIS_EXTERNAL_DB_LIVE_QUERY_PREFLIGHT_ENABLED=false
# Lease-scoped secret resolution for external DB live queries (default off).
# When enabled, the Postgres DSN is no longer read from a static env DSN at
# startup: it is resolved per query from the credential handle's env:// secret
# reference, only under an active lease with lease_scoped_secret_ref access
# mode. Vault/AWS/GCP/Azure provider profiles fail closed (not implemented).
# Without a static AXIS_EXTERNAL_DB_LIVE_QUERY_DSN, pin the approved endpoint
# via AXIS_EXTERNAL_DB_LIVE_QUERY_ENDPOINT_TARGET_SHA256 (sha256 of host:port).
AXIS_EXTERNAL_DB_LEASE_SCOPED_SECRET_RESOLUTION_ENABLED=false
# AXIS_EXTERNAL_DB_LIVE_QUERY_ENDPOINT_TARGET_SHA256=
# Runtime egress enforcement (default off): before psycopg connects, the
# sha256 of the ACTUAL host:port being dialed must match the profile's pinned
# endpoint target hash and the approved egress-policy evidence; a mismatch
# fails closed as blocked_runtime_egress_target_mismatch. Also applies
# session-level read-only + statement-timeout connection options.
AXIS_EXTERNAL_DB_RUNTIME_EGRESS_ENFORCEMENT_ENABLED=false
# Worker-scheduled connector live sync (default off): the Temporal worker
# registers the axis-connector-scheduled-live-sync schedule and executes
# dispatched governed live-sync runs claim -> batches -> checkpoints ->
# release. Requires the sync-execution and live-sync flags above.
AXIS_CONNECTOR_SCHEDULED_LIVE_SYNC_ENABLED=false
AXIS_CONNECTOR_SCHEDULED_LIVE_SYNC_INTERVAL_SECONDS=3600
AXIS_CONNECTOR_SCHEDULED_LIVE_SYNC_TENANT_ID=tenant_demo_manufacturing
