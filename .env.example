AXIS_ENV=development
AXIS_PUBLIC_BASE_URL=http://localhost:3000
AXIS_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_AXIS_API_BASE_URL=http://localhost:8000
AXIS_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
AXIS_POSTGRES_DSN=postgresql+psycopg://axis:axis@localhost:5432/axis
AXIS_TYPEDB_ADDRESS=localhost:1729
AXIS_TYPEDB_HTTP_ADDRESS=http://localhost:8001
AXIS_TYPEDB_USERNAME=admin
AXIS_TYPEDB_PASSWORD=password
AXIS_TYPEDB_DATABASE=axis
AXIS_ONTOLOGY_MUTATIONS_ENABLED=false
AXIS_ONTOLOGY_QUERIES_ENABLED=false
AXIS_TEMPORAL_ADDRESS=localhost:7233
AXIS_TEMPORAL_NAMESPACE=default
AXIS_TEMPORAL_SIGNAL_TIMEOUT_SECONDS=2.0
AXIS_WORKFLOW_SIGNALS_ENABLED=true
AXIS_OBJECT_STORE_ENDPOINT=http://localhost:9000
AXIS_OBJECT_STORE_BUCKET=axis-dev
AXIS_OIDC_ISSUER=http://localhost:8080/realms/axis
AXIS_OIDC_AUDIENCE=limes-axis-api
AXIS_OIDC_JWKS_URL=http://localhost:8080/realms/axis/protocol/openid-connect/certs
AXIS_OIDC_ALGORITHMS=["RS256"]
AXIS_OIDC_ACTOR_CLAIM=sub
AXIS_OIDC_TENANT_CLAIM=axis_tenant
AXIS_OIDC_JWKS_CACHE_SECONDS=300
AXIS_OIDC_AUTH_REQUIRED=false
AXIS_EXTERNAL_MODEL_EGRESS_ENABLED=false
AXIS_CREDENTIAL_LEASE_EXECUTION_ENABLED=false
