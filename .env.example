AXIS_ENV=development
AXIS_PUBLIC_BASE_URL=http://127.0.0.1:3000
AXIS_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_AXIS_API_BASE_URL=http://127.0.0.1:8000
AXIS_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
AXIS_POSTGRES_DSN=postgresql+psycopg://axis:axis@localhost:5432/axis
AXIS_TYPEDB_ADDRESS=localhost:1729
AXIS_TYPEDB_HTTP_ADDRESS=http://localhost:8001
AXIS_TYPEDB_USERNAME=admin
AXIS_TYPEDB_PASSWORD=password
AXIS_TYPEDB_DATABASE=axis
AXIS_ONTOLOGY_MUTATIONS_ENABLED=false
AXIS_ONTOLOGY_QUERIES_ENABLED=false
AXIS_TEMPORAL_ADDRESS=localhost:7233
AXIS_TEMPORAL_NAMESPACE=default
AXIS_TEMPORAL_SIGNAL_TIMEOUT_SECONDS=2.0
AXIS_WORKFLOW_SIGNALS_ENABLED=true
AXIS_OBJECT_STORE_ENDPOINT=http://localhost:9000
AXIS_OBJECT_STORE_BUCKET=axis-dev
AXIS_OIDC_ISSUER=http://127.0.0.1:8080/realms/axis
AXIS_OIDC_AUDIENCE=limes-axis-api
AXIS_OIDC_JWKS_URL=http://127.0.0.1:8080/realms/axis/protocol/openid-connect/certs
AXIS_OIDC_ALGORITHMS=["RS256"]
AXIS_OIDC_ACTOR_CLAIM=sub
AXIS_OIDC_TENANT_CLAIM=axis_tenant
AXIS_OIDC_JWKS_CACHE_SECONDS=300
AXIS_OIDC_AUTH_REQUIRED=false
AXIS_OIDC_CLIENT_ID=limes-axis-web
AXIS_OIDC_CLIENT_SECRET=axis-local-dev-secret
AXIS_OIDC_AUTHORIZATION_URL=http://127.0.0.1:8080/realms/axis/protocol/openid-connect/auth
AXIS_OIDC_TOKEN_URL=http://127.0.0.1:8080/realms/axis/protocol/openid-connect/token
AXIS_OIDC_REDIRECT_URI=http://127.0.0.1:8000/identity/oidc/callback
AXIS_OIDC_END_SESSION_URL=http://127.0.0.1:8080/realms/axis/protocol/openid-connect/logout
AXIS_OIDC_POST_LOGOUT_REDIRECT_URI=http://127.0.0.1:3000/
AXIS_OIDC_SESSION_COOKIE_SIGNING_SECRET=axis-local-demo-session-signing-key
AXIS_OIDC_SESSION_COOKIE_SECURE=false
AXIS_OIDC_SESSION_COOKIE_HOST_PREFIX=true
AXIS_OIDC_SESSION_IDLE_TIMEOUT_SECONDS=1800
AXIS_OIDC_SESSION_ABSOLUTE_TIMEOUT_SECONDS=28800
AXIS_OIDC_SESSION_MAX_CONCURRENT=5
AXIS_OIDC_REFRESH_TOKEN_ENCRYPTION_KEY=axis-local-demo-refresh-credential-key
AXIS_EXTERNAL_MODEL_EGRESS_ENABLED=false
AXIS_DEPLOYMENT_TENANCY_MODE=saas_multi_tenant
AXIS_DEPLOYMENT_CUSTOMER_ISOLATION_CONFIGURED=false
AXIS_DEPLOYMENT_DATA_RESIDENCY_CONFIGURED=false
AXIS_DEPLOYMENT_OPERATOR_ACCESS_RUNBOOK_CONFIGURED=false
AXIS_DEPLOYMENT_BREAK_GLASS_APPROVAL_CONFIGURED=false
AXIS_CREDENTIAL_LEASE_EXECUTION_ENABLED=false
AXIS_CREDENTIAL_LEASE_PROVIDER_ADAPTERS_ENABLED=false
AXIS_CONNECTOR_SYNC_EXECUTION_ENABLED=false
AXIS_EXTERNAL_DB_SYNC_EXECUTION_ENABLED=false
AXIS_EXTERNAL_DB_LIVE_QUERY_PREFLIGHT_ENABLED=false
