{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.limeslabs.eu/axis/tenant.schema.json",
  "title": "Limes Axis Tenant Record",
  "description": "A platform tenant lifecycle record as returned by the /platform/tenants API. Mirrors the TenantRecord component of the generated OpenAPI contract.",
  "type": "object",
  "required": [
    "tenant_id",
    "display_name",
    "status",
    "created_by",
    "audit_event_type",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "default": ""
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "suspended",
        "pending_deletion"
      ]
    },
    "created_by": {
      "type": "string",
      "minLength": 1
    },
    "suspended_at": {
      "anyOf": [
        {
          "type": "string",
          "format": "date-time"
        },
        {
          "type": "null"
        }
      ]
    },
    "suspended_by": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "suspension_reason": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "reactivated_at": {
      "anyOf": [
        {
          "type": "string",
          "format": "date-time"
        },
        {
          "type": "null"
        }
      ]
    },
    "reactivated_by": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "provision_idempotency_key": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "bootstrap_admin_actor_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "idempotent_replay": {
      "type": "boolean",
      "default": false
    },
    "permission_decision": {
      "anyOf": [
        {
          "$ref": "#/$defs/permission_decision"
        },
        {
          "type": "null"
        }
      ]
    },
    "audit_event_id": {
      "anyOf": [
        {
          "type": "string",
          "format": "uuid"
        },
        {
          "type": "null"
        }
      ]
    },
    "audit_event_type": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "permission_decision": {
      "type": "object",
      "required": [
        "allowed",
        "reason"
      ],
      "properties": {
        "allowed": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
